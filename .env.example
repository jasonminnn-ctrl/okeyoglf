# OkeyGolf OS — Environment Variables
# Copy this file to .env and fill in actual values.
# NEVER commit .env with real credentials to version control.

# ──────────────────────────────────
# Supabase (Lovable Cloud) — PUBLIC / Publishable keys only
# These are safe to expose in frontend code (anon key, project URL).
# ──────────────────────────────────
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# ──────────────────────────────────
# PRIVATE / Server-side secrets
# These must NEVER appear in frontend code.
# Store them in Lovable Cloud secrets or Supabase Edge Function secrets.
# ──────────────────────────────────
# SUPABASE_SERVICE_ROLE_KEY=       (Edge Functions only)
# OPENAI_API_KEY=                  (Edge Functions only — Phase 8+)
# KAKAO_API_KEY=                   (Edge Functions only — Phase 8+)
